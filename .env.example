# ---------------------------------------------------------------------------
# Pagewright environment
#
# Copy to `apps/web/.env.local` (or set in Netlify). With NOTHING set, the app
# runs in DEMO (mock) mode: sign-in mints a demo session and all GitHub calls
# are served from an in-memory provider — no credentials required.
# ---------------------------------------------------------------------------

# Auth strategy: "app" (GitHub App, preferred), "oauth" (OAuth App fallback),
# or "mock" (demo). Leave unset to auto-detect from the credentials below,
# falling back to mock.
# PAGEWRIGHT_AUTH_MODE=mock

# Public base URL used to build the OAuth redirect URI. Defaults to
# http://localhost:3000 in dev; set to your Netlify URL in production.
# PAGEWRIGHT_APP_URL=https://your-app.netlify.app

# Session cookie encryption key. REQUIRED in production. Must be >= 32 chars.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# --- GitHub App (preferred) ----------------------------------------------
# The app's OAuth client id/secret drive the user-to-server sign-in flow.
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# The App id + private key are only needed for installation tokens (server
# automation). The PEM may use literal \n escapes.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=

# --- OAuth App (fallback) ------------------------------------------------
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# --- Demo mode tweaks ----------------------------------------------------
# The demo user's GitHub login (mock mode only).
# PAGEWRIGHT_MOCK_LOGIN=octocat
