{
  "name": "@pagewright/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pagewright builder app — Next.js (App Router) + shadcn, deployed on Netlify.",
  "scripts": {
    "prebundle": "node ../../scripts/build-provision-bundle.mjs",
    "bundle": "node ../../scripts/build-provision-bundle.mjs",
    "predev": "node ../../scripts/build-provision-bundle.mjs",
    "dev": "next dev",
    "prebuild": "node ../../scripts/build-provision-bundle.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pretypecheck": "node ../../scripts/build-provision-bundle.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/landing.test.mjs"
  },
  "dependencies": {
    "@measured/puck": "^0.20.2",
    "@pagewright/blocks": "workspace:*",
    "@pagewright/github": "workspace:*",
    "@pagewright/registry": "workspace:*",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.469.0",
    "marked": "^18.0.5",
    "next": "^15.1.3",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/turndown": "^5.0.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
