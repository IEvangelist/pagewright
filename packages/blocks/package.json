{
  "name": "@pagewright/blocks",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared React block components + Zod schema rendered by both the Pagewright builder and generated Astro sites.",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./blocks.css": "./src/styles/blocks.css"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  }
}
