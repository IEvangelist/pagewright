{
  "title": "Blog",
  "description": "Notes, updates, and ideas.",
  "slug": "/",
  "draft": false,
  "blocks": [
    {
      "type": "navbar",
      "id": "nav-1",
      "props": {
        "brand": "{{site.name}}",
        "links": [
          { "label": "Posts", "href": "#posts" },
          { "label": "About", "href": "#about" }
        ],
        "cta": { "label": "Subscribe", "href": "#subscribe" }
      }
    },
    {
      "type": "hero",
      "id": "hero-1",
      "props": {
        "eyebrow": "Writing in the open",
        "heading": "{{site.name}}",
        "subheading": "Notes, updates, and ideas written visually and published straight from GitHub.",
        "align": "center"
      }
    },
    {
      "type": "footer",
      "id": "footer-1",
      "props": {
        "brand": "{{site.name}}",
        "tagline": "Published with Pagewright.",
        "links": [
          { "label": "GitHub", "href": "https://github.com", "icon": "github" },
          { "label": "RSS", "href": "#", "icon": "rss" }
        ],
        "copyright": "© {{currentYear}} {{site.name}}"
      }
    }
  ]
}
